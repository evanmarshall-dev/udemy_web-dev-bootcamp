{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["airbnb-base", "plugin:prettier/recommended"],
  "overrides": [],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["prettier"],
  "rules": {
    "no-console": "off",
    "no-alert": "off",
    "radix": "off",
    "no-restricted-syntax": "off",
    "func-names": "off",
    "guard-for-in": "off",
    "no-param-reassign": "off"
  }
}
