<!-- This could be named anything other than index, but this is common process for showing all comments or all of any given resource. -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comments Index</title>
  </head>
  <body>
    <h1>Comments</h1>
    <ul>
      <% for(let c of comments) { %>
      <li>
        <%= c.comment %> - <b><%= c.username %></b>
        <a href="/comments/<%= c.id %>">Details</a>
      </li>
      <% } %>
    </ul>
    <a href="/comments/new">Make a New Comment</a>
  </body>
</html>
