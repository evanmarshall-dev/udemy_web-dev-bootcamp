<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Show</title>
  </head>
  <body>
    <h1>Comment ID: <%= comment.id %></h1>
    <h2><%= comment.comment %> - <%= comment.username %></h2>
    <a href="/comments">Back to Comment List</a>
    <a href="/comments/<%= comment.id %>/edit">Edit Comment</a>
    <!-- In form action we are using method override and specifying DELETE. -->
    <form action="/comments/<%= comment.id %>?_method=DELETE" method="post">
      <button>Delete</button>
    </form>
  </body>
</html>
